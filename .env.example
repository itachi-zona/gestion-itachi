# Cadena de conexión de Neon (Neon Console > Connection string > "Pooled connection")
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Clave secreta para firmar las sesiones (invéntate una cadena larga y aleatoria)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Clave de la API de Groq (gratis, en console.groq.com > API Keys) para el Chat IA
GROQ_API_KEY="gsk_..."
